{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "noEmit": true,
        "allowImportingTsExtensions": true,
        "skipLibCheck": true,
        "types": ["bun-types"]
    },
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules"]
}
